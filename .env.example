# Copy to .env and fill in real values before running docker-compose.

# Path to the SQLite database inside the container
DB_PATH=/app/demo.db

# Query limits
ROW_LIMIT=100000
WORKER_THREADS=4
QUERY_TIMEOUT_SECONDS=300

# Redis (set automatically by docker-compose; override for external Redis)
REDIS_URL=redis://redis:6379/0
JOB_TTL_SECONDS=86400

# API keys — replace with keys loaded from your secret manager.
# Format: JSON object mapping key string → {"name": "display name"}
# Example: {"sk-prod-abc123": {"name": "alice"}, "sk-prod-def456": {"name": "bob"}}
API_KEYS_JSON={"alice":{"name":"alice"},"bob":{"name":"bob"}}
