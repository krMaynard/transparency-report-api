# Copy to .env and fill in real values before running docker-compose.

# Path to the SQLite database inside the container
DB_PATH=/app/demo.db

# Query limits
ROW_LIMIT=100000
WORKER_THREADS=4
QUERY_TIMEOUT_SECONDS=300

# Redis — choose ONE of the two options below:

# Option A: Upstash (recommended — paste your REST URL and token from the Upstash dashboard)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Option B: standard Redis URL (self-hosted or other managed provider)
# REDIS_URL=redis://redis:6379/0

JOB_TTL_SECONDS=86400

# Secure download URLs — HMAC secret for signing result download links.
# Set a stable, random value (e.g. `openssl rand -hex 32`) so signed links
# survive restarts and validate across multiple workers.
DOWNLOAD_URL_SECRET=change-me-to-a-long-random-secret
DOWNLOAD_URL_TTL_SECONDS=3600

# Researcher portal — issued API key lifetime and registration rate limit.
# Issued keys persist in Redis (above) when configured, else in-memory.
ISSUED_KEY_TTL_SECONDS=2592000
PORTAL_REGISTER_MAX_PER_WINDOW=10
PORTAL_REGISTER_WINDOW_SECONDS=3600
# Set to 1 ONLY behind a trusted proxy that overwrites X-Forwarded-For, so the
# registration rate limit keys off the real client IP. Leaving it off (default)
# uses the socket peer IP, which clients can't spoof. With
# `uvicorn --proxy-headers --forwarded-allow-ips=…` you don't need this.
TRUST_PROXY_HEADERS=0

# Per-API-key throttle on POST /query (the job-spawning path) -> 429 + Retry-After.
QUERY_RATE_MAX_PER_WINDOW=60
QUERY_RATE_WINDOW_SECONDS=60

# Public interactive query (POST /api/explore, no auth): hard row cap + per-IP
# rate limit so the open endpoint can't be abused.
EXPLORE_MAX_ROWS=500
EXPLORE_RATE_MAX_PER_WINDOW=60
EXPLORE_RATE_WINDOW_SECONDS=60

# Natural-language queries (POST /api/ask). Set ANTHROPIC_API_KEY to enable — an
# LLM translates questions into the structured query (never SQL). Off if unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ASK_RATE_MAX_PER_WINDOW=10
ASK_RATE_WINDOW_SECONDS=60
# Cache translated questions in-process (repeat question → no LLM call).
ASK_CACHE_SIZE=256

# Structured logging: json (default) emits one JSON object per line; text is
# human-readable. LOG_LEVEL sets the threshold for the api_demo logger.
LOG_LEVEL=INFO
LOG_FORMAT=json

# Webhook callbacks (optional callback_url on POST /query).
# PUBLIC_BASE_URL makes the links in the callback payload absolute (else relative).
PUBLIC_BASE_URL=https://api.example.com
CALLBACK_TIMEOUT_SECONDS=10
CALLBACK_MAX_ATTEMPTS=3
CALLBACK_WORKERS=8
# Leave at 0 in production: the SSRF guard blocks callbacks to private/loopback/
# link-local addresses. Set to 1 only for local development against a local sink.
CALLBACK_ALLOW_PRIVATE=0

# API keys — replace with keys loaded from your secret manager.
# Format: JSON object mapping key string → {"name": "display name"}
# Example: {"sk-prod-abc123": {"name": "alice"}, "sk-prod-def456": {"name": "bob"}}
API_KEYS_JSON={"alice":{"name":"alice"},"bob":{"name":"bob"}}

# ── Google sign-in + admin approval ──────────────────────────────────────────
# OAuth 2.0 Web client ID; Google ID tokens are verified against it. Leave unset
# to disable Google sign-in (the portal then shows only the demo form).
GOOGLE_CLIENT_ID=
# Comma-separated admin allowlist — implicitly approved, may approve/revoke others.
ADMIN_EMAILS=
# Lifetime of a first-party session minted after a successful Google login.
GOOGLE_SESSION_TTL_SECONDS=604800
# Demo auth: hardcoded alice/bob keys + the open /portal/register flow. Handy for
# local dev; set to 0 in production so only Google sign-in works.
ALLOW_DEMO_KEYS=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API cross-origin. Empty =
# same-origin only (no CORS headers); the bundled portal is same-origin.
ALLOWED_ORIGINS=

# ── Build identifier ─────────────────────────────────────────────────────────
# Surfaced at GET /version and the X-Version header. The CD workflow injects the
# commit SHA on Cloud Run; defaults to "dev" if unset.
APP_VERSION=
